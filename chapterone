<script>
// ===========================================================================
// PYODIDE LOADING
// ===========================================================================
let pyodide = null;
let pyodideLoading = false;

async function loadPyodideOnce() {
  if (pyodide) return pyodide;
  if (pyodideLoading) {
    while (!pyodide) await new Promise(r => setTimeout(r, 100));
    return pyodide;
  }
  pyodideLoading = true;
  pyodide = await loadPyodide();
  return pyodide;
}

async function runPython(code) {
  const py = await loadPyodideOnce();
  let stdout = '';
  py.setStdout({ batched: (s) => { stdout += s + '\n'; } });
  py.setStderr({ batched: (s) => { stdout += s + '\n'; } });
  try {
    await py.runPythonAsync(code);
    return { ok: true, output: stdout };
  } catch (err) {
    return { ok: false, output: stdout, error: String(err.message || err) };
  }
}

// ===========================================================================
// SAVE / LOAD STATE (Neocities-friendly: localStorage only)
// ===========================================================================
const SAVE_KEY = 'pyforthegirls_save_v1';

function loadSave() {
  try {
    const raw = localStorage.getItem(SAVE_KEY);
    if (!raw) return null;
    return JSON.parse(raw);
  } catch (e) { return null; }
}

function writeSave(data) {
  try { localStorage.setItem(SAVE_KEY, JSON.stringify(data)); } catch(e) {}
}

let state = loadSave() || {
  userName: '',
  currentBeat: 0,
  completedBeats: [],
  charms: 0
};

// ===========================================================================
// SPARKLES
// ===========================================================================
function makeSparkles() {
  const container = document.getElementById('sparkles');
  for (let i = 0; i < 14; i++) {
    const s = document.createElement('div');
    s.className = 'sparkle';
    s.style.left = Math.random() * 100 + '%';
    s.style.top = Math.random() * 100 + '%';
    s.style.animationDelay = Math.random() * 3 + 's';
    s.style.animationDuration = (2 + Math.random() * 3) + 's';
    container.appendChild(s);
  }
}

// ===========================================================================
// INTRO -> DESKTOP
// ===========================================================================
document.getElementById('startBtn').addEventListener('click', startGame);
document.getElementById('userNameInput').addEventListener('keydown', e => {
  if (e.key === 'Enter') startGame();
});

function startGame() {
  const name = document.getElementById('userNameInput').value.trim() || 'guest';
  state.userName = name;
  writeSave(state);
  document.getElementById('introScreen').classList.add('hidden');
  document.getElementById('desktop').classList.remove('hidden');
  document.getElementById('taskbar').classList.remove('hidden');
  makeSparkles();
  startClock();
  renderStory();
}

function startClock() {
  const start = Date.now();
  setInterval(() => {
    // we keep the in-fiction clock at 11:47 PM, ticking up unsettlingly
    const elapsed = Math.floor((Date.now() - start) / 60000);
    const hh = 11;
    const mm = (47 + elapsed) % 60;
    document.getElementById('taskbarTime').textContent =
      `${hh}:${String(mm).padStart(2,'0')} PM`;
  }, 1000);
}

// ===========================================================================
// CONTENT — STORY BEATS
// Each beat is either a 'diary' card (pure narrative) or a 'task' card
// (story + Python challenge). Player progresses linearly.
// ===========================================================================
const BEATS = [

  // ---- BEAT 0: opening diary entry ----
  {
    id: 'diary_0',
    type: 'diary',
    title: 'open file: diary/01_first_day.txt',
    meta: 'last modified: june 21, 2004 — 10:42 pm',
