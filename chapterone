// ===========================================================================
// TASK EXECUTION
// ===========================================================================
async function runTask(beatId) {
const beat = BEATS.find(b => b.id === beatId);
const codeEl = document.getElementById('code-' + beatId);
const outEl = document.getElementById('output-' + beatId);

// Normalize smart quotes that mobile keyboards inject.
// Python only accepts straight quotes, so we replace curly ones silently.
let code = codeEl.value
.replace(/[\u2018\u2019\u201A\u201B\u2032]/g, "'")  // single curly -> straight
.replace(/[\u201C\u201D\u201E\u201F\u2033]/g, '"')  // double curly -> straight
.replace(/[\u2013\u2014]/g, '-')                     // en/em dash -> hyphen
.replace(/\u00A0/g, ' ');                            // non-breaking space -> regular space
// Reflect the cleanup in the textarea so the user can see what's actually being run
if (code !== codeEl.value) codeEl.value = code;

outEl.innerHTML = `<span class="info">// booting python interpreter...
// (~10 seconds on first run, instant after that)
// ▰▰▱▱▱▱▱▱▱▱</span>`;

// Patch input() if needed
let runCode = code;
if (beat.fakeInput !== undefined) {
// monkey-patch input() to return our fake value
runCode = `
import builtins
__fake_input_value = ${JSON.stringify(beat.fakeInput)}
__orig_input = builtins.input
def __patched_input(prompt=""):
    print(prompt + __fake_input_value)
    return __fake_input_value
builtins.input = __patched_input
` + code;
}

const result = await runPython(runCode);
const actualOutput = (result.output || '').trimEnd();

if (!result.ok) {
outEl.innerHTML = `<span class="err">// ERROR\n${escapeHtml(result.error)}</span>${result.output ? '\n<span class="info">' + escapeHtml(actualOutput) + '</span>' : ''}\n<span class="info">// hint: read the error message. it usually tells you which line and what kind of mistake.</span>`;
return;
}

// Check expected output
let passed = false;
if (beat.matchType === 'exact') {
passed = actualOutput.trim() === beat.expectedOutput.trim();
} else if (beat.matchType === 'contains') {
passed = actualOutput.includes(beat.expectedOutput);
}

if (passed) {
outEl.innerHTML = `<span class="ok">${escapeHtml(actualOutput) || '(no output)'}\n\n✦ TEST PASSED ✦\n${beat.onComplete?.diary || ''}</span>`;
// mark complete
if (!state.completedBeats.includes(beat.id)) {
state.completedBeats.push(beat.id);
state.charms += (beat.charms || 0);
// store the working code
beat.completedCode = code;
writeSave(state);
}
// show buddy popup
if (beat.onComplete?.buddy) {
showBuddy(beat.onComplete.buddy.name, beat.onComplete.buddy.msg);
}
// re-render to show "continue" button
setTimeout(() => renderStory(), 600);
} else {
outEl.innerHTML = `<span class="info">${escapeHtml(actualOutput) || '(no output)'}\n</span><span class="err">// expected output:\n${escapeHtml(beat.expectedOutput)}\n\n// not quite. try again.</span>`;
}
}

function resetTask(beatId) {
const beat = BEATS.find(b => b.id === beatId);
document.getElementById('code-' + beatId).value = beat.starter;
document.getElementById('output-' + beatId).innerHTML = `<span class="info">// awaiting execution...</span>`;
}

function escapeHtml(s) {
return String(s).replace(/[&<>]/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;'}[c]));
}

// ===========================================================================
// BEAT ADVANCE
// ===========================================================================
function advanceBeat() {
// mark diary beats as "completed" implicitly (they only need to be read)
const beat = BEATS[state.currentBeat];
if (beat && beat.type === 'diary' && !state.completedBeats.includes(beat.id)) {
state.completedBeats.push(beat.id);
}
state.currentBeat = Math.min(state.currentBeat + 1, BEATS.length - 1);
writeSave(state);
renderStory();
}

function resetGame() {
if (confirm('really restart from the beginning? all your progress will be erased.')) {
localStorage.removeItem(SAVE_KEY);
location.reload();
}
}

// ===========================================================================
// BUDDY POPUP
// ===========================================================================
function showBuddy(name, msg) {
document.getElementById('buddyName').textContent = name + ' :: incoming message';
document.getElementById('buddyMessage').innerHTML = msg;
const popup = document.getElementById('buddyPopup');
popup.classList.remove('hidden');
// play a soft chime — emulated as a CSS attention grab
popup.style.animation = 'none';
setTimeout(() => { popup.style.animation = ''; }, 10);
}
function closeBuddy() {
document.getElementById('buddyPopup').classList.add('hidden');
}

// auto-resume from save
if (state.userName && state.currentBeat > 0) {
// skip intro
document.getElementById('userNameInput').value = state.userName;
// keep intro visible but offer continue — simpler: go straight in
setTimeout(() => {
document.getElementById('introScreen').classList.add('hidden');
document.getElementById('desktop').classList.remove('hidden');
document.getElementById('taskbar').classList.remove('hidden');
makeSparkles();
startClock();
renderStory();
}, 100);
}
