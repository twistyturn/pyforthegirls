// ===========================================================================
// RENDER STORY (linear, append-as-you-go)
// ===========================================================================
const storyContainer = document.getElementById('storyContainer');

function renderStory() {
  storyContainer.innerHTML = '';
  // render all completed beats, then current beat
  const upTo = Math.min(state.currentBeat, BEATS.length - 1);
  for (let i = 0; i <= upTo; i++) {
    renderBeat(BEATS[i], i === upTo);
  }
  // scroll to bottom
  setTimeout(() => window.scrollTo({ top: document.body.scrollHeight, behavior: 'smooth' }), 100);
}

function renderBeat(beat, isActive) {
  if (beat.type === 'diary') return renderDiary(beat, isActive);
  if (beat.type === 'task') return renderTask(beat, isActive);
  if (beat.type === 'wrap') return renderWrap(beat, isActive);
}

function renderDiary(beat, isActive) {
  const w = document.createElement('div');
  w.className = 'window story-window';
  w.innerHTML = `
    <div class="window-titlebar">
      <span>${beat.title}</span>
      <div class="window-titlebar-buttons">
        <span class="titlebar-btn">_</span>
        <span class="titlebar-btn">□</span>
        <span class="titlebar-btn">×</span>
      </div>
    </div>
    <div class="diary-entry">
      <div class="diary-meta">${beat.meta}</div>
${beat.body.split('\n').map(l => l || '&nbsp;').join('<br>')}
    </div>
    ${isActive ? `<div style="padding: 12px; text-align: center; background: var(--window-bg); border-top: 1px solid var(--bg-deep);">
      <button class="btn" onclick="advanceBeat()">${beat.nextBtn || 'continue ▸'}</button>
    </div>` : ''}
  `;
  storyContainer.appendChild(w);
}

